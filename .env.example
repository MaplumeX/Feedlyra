# Feedlyra Docker Compose deployment configuration.
# Copy this file to `.env` and edit the values before running `docker compose up -d --build`.
#   cp .env.example .env

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_USER=feedlyra
POSTGRES_PASSWORD=change-me
POSTGRES_DB=feedlyra

# DATABASE_URL is resolved inside the compose network where the db service is named `db`.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ----------------------------------------------------------------------------
# Backend (security / tokens)
# IMPORTANT: change SECRET_KEY to a strong random value in production.
#           e.g. `python3 -c "import secrets; print(secrets.token_urlsafe(48))"`
# ----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Allowed frontend origins (comma-separated). Same-origin via nginx, kept for local dev.
CORS_ORIGINS=http://localhost:7756

# Where uploaded chat images are stored (mounted on the feedlyra_uploads volume).
UPLOAD_DIR=/app/uploads/chat_images

# ----------------------------------------------------------------------------
# AI provider (fill in your own key)
# ----------------------------------------------------------------------------
AI_DEFAULT_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# Frontend host port mapping
# ----------------------------------------------------------------------------
FRONTEND_PORT=7756
